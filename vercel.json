{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 17 * * 2"
    },
    {
      "path": "/api/indexnow",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/mustard-sequence",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/commissions",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/outreach-cadence",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/booking-reminders",
      "schedule": "0 14 * * 2-5"
    },
    {
      "path": "/api/cron/lead-digest",
      "schedule": "0 15 * * 1-5"
    },
    {
      "path": "/api/cron/operator",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/cron/outbound-audits",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/outbound-cadence",
      "schedule": "0 18 * * 1-5"
    },
    {
      "path": "/api/cron/pilot-usage",
      "schedule": "0 12 * * *"
    }
  ]
}
