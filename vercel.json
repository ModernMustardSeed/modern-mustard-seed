{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 17 * * 2"
    },
    {
      "path": "/api/indexnow",
      "schedule": "0 6 * * 1"
    }
  ]
}
