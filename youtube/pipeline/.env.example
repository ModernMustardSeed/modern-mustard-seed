# Copy to .env and fill in. Never commit .env.

# ElevenLabs (your cloned voice)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# eleven_multilingual_v2 (quality) or eleven_turbo_v2_5 (fast/cheap)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Higgsfield uses browser OAuth via `higgsfield auth login` — no key needed here.
